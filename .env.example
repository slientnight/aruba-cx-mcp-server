# =============================================================================
# Aruba CX MCP Server
# Python MCP server for Aruba CX switch management (16 tools: 11 read, 5 write)
# =============================================================================

# Target switch definitions as a JSON array.
# Each target requires: name, host, username, password
# Optional fields: port (default 443), api_version (default "v10.13"), verify_ssl (default true)
# ARUBA_CX_TARGETS='[{"name":"core-switch-1","host":"10.0.1.1","username":"admin","password":"secret","port":443,"api_version":"v10.13","verify_ssl":true}]'

# Global SSL verification for switch connections (default: true)
# ARUBA_CX_VERIFY_SSL=true

# Request timeout in seconds (default: 30)
# ARUBA_CX_TIMEOUT=30

# Enable ITSM gate for write operations (default: false)
# When true, write tools require a valid Change Request number (CHG + digits).
# When false or unset, write tools operate without CR validation.
# ITSM_ENABLED=false

# Lab mode — format-only CR validation, skip external checks (default: false)
# ITSM_LAB_MODE=false
